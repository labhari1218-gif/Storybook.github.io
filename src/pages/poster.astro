---
import BaseLayout from "../layouts/BaseLayout.astro";
import tenaliRama from "../assets/images/tenali-rama-web.jpg";

const storybookUrl = "https://labhari1218-gif.github.io/Storybook.github.io/";
const qrUrl = `${import.meta.env.BASE_URL}storybook-qr.svg`;
---

<BaseLayout
  title="Storybook Poster"
  description="Poster for the Telugu storybook with a QR code to open the site."
>
  <main class="flex h-screen items-center justify-center overflow-hidden bg-[#efe0c4] p-3 text-[#231914]">
    <section class="mx-auto flex h-full max-h-[calc(100vh-1.5rem)] aspect-[4/5] w-full max-w-[760px] flex-col overflow-hidden rounded-[40px] border border-[rgba(88,56,33,0.16)] bg-[linear-gradient(180deg,#fbf4e7_0%,#f2e2c4_100%)] shadow-[0_28px_70px_rgba(28,16,8,0.22)]">
      <div class="relative flex h-full flex-col px-6 pb-5 pt-6">
        <div class="absolute inset-x-0 top-0 h-32 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.7),transparent_70%)]"></div>

        <div class="relative z-10">
          <p class="text-[0.82rem] font-semibold uppercase tracking-[0.26em] text-[#97512f]">
            Telugu Storybook
          </p>
          <h1 class="mt-3 max-w-[13ch] font-[var(--font-display)] text-[2.8rem] leading-[0.92] text-[#2d1d16] md:text-[3.1rem]">
            Scan to explore the stories
          </h1>
          <p class="mt-3 max-w-[20rem] text-[0.96rem] leading-7 text-[#654d3d]">
            A small phone-first book of Tenali wit, Telugu sound, Vemana, temple hills, and Sriharikota.
          </p>
        </div>

        <div class="relative z-10 mt-5 grid flex-1 gap-4 md:grid-cols-[1fr,220px] md:items-end">
          <div class="relative flex min-h-0 flex-col justify-between">
            <div class="max-w-[14rem] rounded-[26px] border border-[rgba(88,56,33,0.14)] bg-[rgba(255,250,242,0.96)] px-4 py-3 shadow-[0_16px_30px_rgba(52,31,19,0.08)]">
              <p class="text-[0.82rem] font-semibold uppercase tracking-[0.18em] text-[#97512f]">
                Open on phone
              </p>
              <p class="mt-2 text-[0.95rem] leading-7 text-[#3c2a22]">
                Point your camera here and start reading.
              </p>
            </div>

            <svg
              class="pointer-events-none absolute right-[-0.4rem] top-[4.5rem] h-[102px] w-[144px] text-[#97512f]"
              viewBox="0 0 160 120"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M5 112C44 95 66 80 95 44C111 24 126 16 154 10"
                stroke="currentColor"
                stroke-width="6"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-dasharray="2 14"
              />
              <path
                d="M132 7L154 10L140 28"
                stroke="currentColor"
                stroke-width="6"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>

            <div class="mt-4 w-[56%] max-w-[232px] overflow-hidden rounded-[30px] border border-[rgba(88,56,33,0.12)] bg-[rgba(255,251,246,0.62)] shadow-[0_18px_45px_rgba(42,24,13,0.14)]">
              <img
                src={tenaliRama.src}
                width={tenaliRama.width}
                height={tenaliRama.height}
                alt="Tenali Rama image accompanying the QR storybook poster"
                class="block h-[220px] w-full object-cover object-top"
              />
            </div>
          </div>

          <div class="self-center rounded-[28px] border border-[rgba(88,56,33,0.16)] bg-[rgba(255,252,246,0.96)] p-3 shadow-[0_18px_40px_rgba(42,24,13,0.12)]">
            <div class="rounded-[20px] border border-[rgba(88,56,33,0.12)] bg-white p-2.5">
              <img
                src={qrUrl}
                alt="QR code linking to the Telugu storybook website"
                class="block h-auto w-full"
              />
            </div>
            <p class="mt-4 text-center text-[0.85rem] uppercase tracking-[0.2em] text-[#97512f]">
              Scan to read
            </p>
            <p class="mt-1.5 text-center text-[0.82rem] leading-6 text-[#4d3b2f]">
              Stories, poetry, temples, and skyward dreams.
            </p>
            <p class="mt-1.5 break-all text-center text-[0.69rem] leading-5 text-[#6a5547]">
              {storybookUrl}
            </p>
          </div>
        </div>

        <div class="relative z-10 mt-3 border-t border-[rgba(88,56,33,0.12)] pt-3 text-center text-[0.8rem] leading-6 text-[#5d4a3d]">
          Scan once, open the book, and swipe gently through the pages.
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
