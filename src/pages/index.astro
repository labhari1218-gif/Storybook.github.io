---
import BookShell from "../components/BookShell.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBookScreens, getScreenIndexForSlug } from "../lib/book";

const requestedChapter = Astro.url.searchParams.get("chapter") ?? undefined;
const requestedPage = Number(Astro.url.searchParams.get("page") ?? "1");

const screens = await getBookScreens();
const initialScreen = await getScreenIndexForSlug(requestedChapter, requestedPage);
---

<BaseLayout
  title="A Little Book of Telugu Wonder"
  description="A premium QR-first Telugu mini book with Ugadi greetings, Tenali stories, poetry, temples, and Sriharikota."
>
  <BookShell screens={screens} initialScreen={initialScreen} />
</BaseLayout>
